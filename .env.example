# ============================================================
# CarnageReporter - Variables de entorno (servidor)
# Copia este archivo a .env y llena los valores reales.
# NUNCA subas el .env a git.
# ============================================================

# ----- Servidor -----
PORT=3000
# Key que los clientes mandan en el header X-API-Key (elige una cadena aleatoria larga)
API_KEY=
# Key de administración para endpoints /api/admin/* (distinta a API_KEY)
ADMIN_KEY=

# ----- Supabase (Project Settings > API) -----
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=

# ----- Discord -----
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ----- Stripe (opcional, donaciones) -----
STRIPE_SECRET_KEY=

# ----- WhatsApp (opcional) -----
WHATSAPP_ENABLED=false
# Grupo de 2v2 (Retas H3) — ID o nombre
WHATSAPP_GROUP_ID=
WHATSAPP_GROUP_NAME=
# Grupo de 4v4 (Torneos Halo 3) — ID o nombre
WHATSAPP_GROUP_ID_4V4=
WHATSAPP_GROUP_NAME_4V4=
# Directorio de sesión persistente (default: server/.wwebjs_auth)
# WHATSAPP_AUTH_DIR=

# ----- Reglas de negocio -----
# Partidas más cortas que esto (segundos) se marcan como anuladas (clientes v2+)
VOID_MIN_DURATION_SECONDS=150
# ...salvo que un equipo haya llegado a este puntaje (2v2): partida real aunque corta
WIN_SCORE_2V2=25
# Mínimo de partidas para competir por tier en el leaderboard
LEADERBOARD_MIN_GAMES=5
# Sesión (!rondas): huecos menores a esto (minutos) = misma noche de retas
SESSION_GAP_MINUTES=150
# Valor de cada ronda ganada (pesos MXN) para la cuenta de la noche
RONDA_MXN=25
